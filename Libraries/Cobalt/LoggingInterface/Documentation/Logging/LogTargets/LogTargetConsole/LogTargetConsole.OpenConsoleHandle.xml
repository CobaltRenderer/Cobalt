      <PageRefListEntry PageName="cobalt.logging.LogTargetConsole">LogTargetConsole</PageRefListEntry>
      <PageRefListEntry PageName="cobalt.logging.LogTargetConsole.CloseConsoleHandle">LogTargetConsole.CloseConsoleHandle</PageRefListEntry>
    </PageRefList>
  </Section>
</XMLDocContent>
