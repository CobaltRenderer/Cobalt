        </FunctionMemberListEntry>
      </FunctionMemberList>
    </SubSection>
    <SubSection Title="Scope methods">
      <FunctionMemberList>
        <FunctionMemberListEntry Visibility="Public" Name="GetScope" PageName="cobalt.logging.ILogger.GetScope">
          Returns the scope string assigned to the logger.
        </FunctionMemberListEntry>
      </FunctionMemberList>
    </SubSection>
    <SubSection Title="Severity methods">
      <FunctionMemberList>
        <FunctionMemberListEntry Visibility="Public" Name="IsLogSeverityEnabled" PageName="cobalt.logging.ILogger.IsLogSeverityEnabled">
          Reports whether a message with the supplied severity would currently be accepted by the logger.
        </FunctionMemberListEntry>
      </FunctionMemberList>
    </SubSection>
    <SubSection Title="Logger creation methods">
      <FunctionMemberList>
        <FunctionMemberListEntry Visibility="Public" Name="CloneLogger" PageName="cobalt.logging.ILogger.CloneLogger">
