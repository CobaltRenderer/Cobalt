        </FunctionMemberListEntry>
        <FunctionMemberListEntry Visibility="Public" Name="GetLoggerChildScope" PageName="cobalt.logging.ILogger.GetLoggerChildScope">
          Creates a logger for a child scope below the current logger scope.
        </FunctionMemberListEntry>
      </FunctionMemberList>
    </SubSection>
    <SubSection Title="Logging methods">
      <FunctionMemberList>
        <FunctionMemberListEntry Visibility="Public" Name="Log" PageName="cobalt.logging.ILogger.Log">
          Logs a message using the severity supplied by the caller.
        </FunctionMemberListEntry>
        <FunctionMemberListEntry Visibility="Public" Name="Critical" PageName="cobalt.logging.ILogger.Critical">
          Logs a critical severity message.
        </FunctionMemberListEntry>
        <FunctionMemberListEntry Visibility="Public" Name="Error" PageName="cobalt.logging.ILogger.Error">
          Logs an error severity message.
        </FunctionMemberListEntry>
        <FunctionMemberListEntry Visibility="Public" Name="Warning" PageName="cobalt.logging.ILogger.Warning">
          Logs a warning severity message.
        </FunctionMemberListEntry>
        <FunctionMemberListEntry Visibility="Public" Name="Info" PageName="cobalt.logging.ILogger.Info">
          Logs an informational severity message.
        </FunctionMemberListEntry>
        <FunctionMemberListEntry Visibility="Public" Name="Debug" PageName="cobalt.logging.ILogger.Debug">
          Logs a debug severity message.
        </FunctionMemberListEntry>
        <FunctionMemberListEntry Visibility="Public" Name="Trace" PageName="cobalt.logging.ILogger.Trace">
          Logs a trace severity message.
        </FunctionMemberListEntry>
      </FunctionMemberList>
