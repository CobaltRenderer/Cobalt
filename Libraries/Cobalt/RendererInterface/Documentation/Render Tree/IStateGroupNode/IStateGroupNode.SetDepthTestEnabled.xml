<XMLDocContent PageName="cobalt.graphics.IStateGroupNode.SetDepthTestEnabled" Title="SetDepthTestEnabled method" xmlns="http://www.cobaltrenderer.com/schema/XMLDocSchema.xsd">
  <Paragraph>
    <PageRef PageName="cobalt.graphics.Welcome">Home</PageRef> ->
    <PageRef PageName="cobalt.graphics.IStateGroupNode">IStateGroupNode</PageRef> ->
    SetDepthTestEnabled
  </Paragraph>
  <Section Title="Description">
    <Paragraph>
      The <TypeRef>SetDepthTestEnabled</TypeRef> method specifies whether fragments from rendered objects will be tested against the depth buffer.
    </Paragraph>
  </Section>
  <Section Title="Usage">
    <Code Language="C++"><![CDATA[void SetDepthTestEnabled(bool state);]]></Code>
    <SubSection Title="Argument list">
      <ArgumentList>
        <ArgumentListEntry Type="bool" Name="state">
          True to enable depth testing, false to disable depth testing.
        </ArgumentListEntry>
      </ArgumentList>
    </SubSection>
  </Section>
  <Section Title="See also">
    <PageRefList>
      <PageRefListEntry PageName="cobalt.graphics.IStateGroupNode">IStateGroupNode</PageRefListEntry>
    </PageRefList>
  </Section>
</XMLDocContent>
