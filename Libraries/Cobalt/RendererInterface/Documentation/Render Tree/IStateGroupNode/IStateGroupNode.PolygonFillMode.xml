<XMLDocContent PageName="cobalt.graphics.IStateGroupNode.PolygonFillMode" Title="PolygonFillMode enumeration" xmlns="http://www.cobaltrenderer.com/schema/XMLDocSchema.xsd">
  <Paragraph>
    <PageRef PageName="cobalt.graphics.Welcome">Home</PageRef> ->
    <PageRef PageName="cobalt.graphics.IStateGroupNode">IStateGroupNode</PageRef> ->
    PolygonFillMode
  </Paragraph>
  <Section Title="Description">
    <Paragraph>
      The <TypeRef>PolygonFillMode</TypeRef> enumeration specifies how polygon primitives are rasterized by an <PageRef PageName="cobalt.graphics.IStateGroupNode">IStateGroupNode</PageRef>.
    </Paragraph>
  </Section>
  <Section Title="Members">
    <EnumMemberList>
      <EnumMemberListEntry Name="Solid">
        Rasterizes polygon interiors normally.
      </EnumMemberListEntry>
      <EnumMemberListEntry Name="Wireframe">
        Rasterizes only polygon edges. This mode requires the PolygonWireframeFillMode device feature to be supported and enabled.
      </EnumMemberListEntry>
    </EnumMemberList>
  </Section>
  <Section Title="See also">
    <PageRefList>
      <PageRefListEntry PageName="cobalt.graphics.IStateGroupNode.SetPolygonFillMode">IStateGroupNode.SetPolygonFillMode</PageRefListEntry>
    </PageRefList>
  </Section>
</XMLDocContent>
