<XMLDocContent PageName="cobalt.graphics.IStateGroupNode.SetBlendEnabled" Title="SetBlendEnabled method" xmlns="http://www.cobaltrenderer.com/schema/XMLDocSchema.xsd">
  <Paragraph>
    <PageRef PageName="cobalt.graphics.Welcome">Home</PageRef> ->
    <PageRef PageName="cobalt.graphics.IStateGroupNode">IStateGroupNode</PageRef> ->
    SetBlendEnabled
  </Paragraph>
  <Section Title="Description">
    <Paragraph>
      The <TypeRef>SetBlendEnabled</TypeRef> method specifies whether blending is enabled for rendered objects.
    </Paragraph>
  </Section>
  <Section Title="Usage">
    <Code Language="C++"><![CDATA[void SetBlendEnabled(bool state);]]></Code>
    <SubSection Title="Argument list">
      <ArgumentList>
        <ArgumentListEntry Type="bool" Name="state">
          True to enable blending, false to disable blending.
        </ArgumentListEntry>
      </ArgumentList>
    </SubSection>
  </Section>
