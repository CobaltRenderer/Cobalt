<XMLDocContent PageName="cobalt.graphics.IStateGroupNode.SetDepthWriteEnabled" Title="SetDepthWriteEnabled method" xmlns="http://www.cobaltrenderer.com/schema/XMLDocSchema.xsd">
  <Paragraph>
    <PageRef PageName="cobalt.graphics.Welcome">Home</PageRef> ->
    <PageRef PageName="cobalt.graphics.IStateGroupNode">IStateGroupNode</PageRef> ->
    SetDepthWriteEnabled
  </Paragraph>
  <Section Title="Description">
    <Paragraph>
      The <TypeRef>SetDepthWriteEnabled</TypeRef> method specifies whether rendered objects will update the depth buffer based on the generated fragment depth values.
    </Paragraph>
  </Section>
  <Section Title="Usage">
    <Code Language="C++"><![CDATA[void SetDepthWriteEnabled(bool state);]]></Code>
    <SubSection Title="Argument list">
      <ArgumentList>
        <ArgumentListEntry Type="bool" Name="state">
          True to allow successful fragments to update the depth buffer, false to leave existing depth values unchanged.
        </ArgumentListEntry>
      </ArgumentList>
    </SubSection>
  </Section>
  <Section Title="See also">
    <PageRefList>
      <PageRefListEntry PageName="cobalt.graphics.IStateGroupNode">IStateGroupNode</PageRefListEntry>
    </PageRefList>
  </Section>
</XMLDocContent>
