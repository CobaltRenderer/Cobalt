<XMLDocContent PageName="cobalt.graphics.IFrameBufferOutput.SetDetachAfterCapture" Title="SetDetachAfterCapture method" xmlns="http://www.cobaltrenderer.com/schema/XMLDocSchema.xsd">
  <Paragraph>
    <PageRef PageName="cobalt.graphics.Welcome">Home</PageRef> ->
    <PageRef PageName="cobalt.graphics.IFrameBufferOutput">IFrameBufferOutput</PageRef> ->
    SetDetachAfterCapture
  </Paragraph>
  <Section Title="Description">
    <Paragraph>
      The <TypeRef>SetDetachAfterCapture</TypeRef> method specifies whether this IFrameBufferOutput object will be detached after capturing a single image.
    </Paragraph>
  </Section>
  <Section Title="Usage">
    <Code Language="C++"><![CDATA[void SetDetachAfterCapture(bool state = true);]]></Code>
    <SubSection Title="Argument list">
      <ArgumentList>
        <ArgumentListEntry Type="bool" Name="state">
          True to automatically detach this capture target after a framebuffer capture completes, false to keep it attached.
        </ArgumentListEntry>
      </ArgumentList>
    </SubSection>
  </Section>
  <Section Title="See also">
    <PageRefList>
      <PageRefListEntry PageName="cobalt.graphics.IFrameBufferOutput">IFrameBufferOutput</PageRefListEntry>
    </PageRefList>
  </Section>
</XMLDocContent>
