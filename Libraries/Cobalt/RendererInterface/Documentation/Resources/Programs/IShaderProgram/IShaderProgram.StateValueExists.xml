<XMLDocContent PageName="cobalt.graphics.IShaderProgram.StateValueExists" Title="StateValueExists method" xmlns="http://www.cobaltrenderer.com/schema/XMLDocSchema.xsd">
  <Paragraph>
    <PageRef PageName="cobalt.graphics.Welcome">Home</PageRef> ->
    <PageRef PageName="cobalt.graphics.IShaderProgram">IShaderProgram</PageRef> ->
    StateValueExists
  </Paragraph>
  <Section Title="Description">
    <Paragraph>
      The <TypeRef>StateValueExists</TypeRef> method returns true if the specified global state value exists.
    </Paragraph>
  </Section>
  <Section Title="Usage">
    <Code Language="C++"><![CDATA[bool StateValueExists(const Marshal::In<std::string>& name) const;]]></Code>
    <SubSection Title="Argument list">
      <ArgumentList>
        <ArgumentListEntry Type="const Marshal::In&lt;std::string&gt;" Name="name">
          The shader-visible resource or input name to look up.
        </ArgumentListEntry>
      </ArgumentList>
    </SubSection>
    <SubSection Title="Return value">
      <ReturnValue Type="bool">
        True if the compiled shader program exposes a state value with the specified name, false otherwise.
      </ReturnValue>
    </SubSection>
  </Section>
  <Section Title="See also">
    <PageRefList>
      <PageRefListEntry PageName="cobalt.graphics.IShaderProgram">IShaderProgram</PageRefListEntry>
    </PageRefList>
  </Section>
</XMLDocContent>
