<XMLDocContent PageName="cobalt.graphics.IDataArray.RemoveOutputCaptureTarget" Title="RemoveOutputCaptureTarget method" xmlns="http://www.cobaltrenderer.com/schema/XMLDocSchema.xsd">
  <Paragraph>
    <PageRef PageName="cobalt.graphics.Welcome">Home</PageRef> ->
    <PageRef PageName="cobalt.graphics.IDataArray">IDataArray</PageRef> ->
    RemoveOutputCaptureTarget
  </Paragraph>
  <Section Title="Description">
    <Paragraph>
      The <TypeRef>RemoveOutputCaptureTarget</TypeRef> method removes the specified output capture target from this data array.
    </Paragraph>
  </Section>
  <Section Title="Usage">
    <Code Language="C++"><![CDATA[void RemoveOutputCaptureTarget(IDataArrayOutput* captureTarget);]]></Code>
    <SubSection Title="Argument list">
      <ArgumentList>
        <ArgumentListEntry Type="IDataArrayOutput*" Name="captureTarget">
          The output capture target to detach from this resource.
        </ArgumentListEntry>
      </ArgumentList>
    </SubSection>
  </Section>
