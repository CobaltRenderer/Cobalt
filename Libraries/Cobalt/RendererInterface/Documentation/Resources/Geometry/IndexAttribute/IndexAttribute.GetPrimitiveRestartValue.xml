<XMLDocContent PageName="cobalt.graphics.IndexAttribute.GetPrimitiveRestartValue" Title="GetPrimitiveRestartValue method" xmlns="http://www.cobaltrenderer.com/schema/XMLDocSchema.xsd">
  <Paragraph>
