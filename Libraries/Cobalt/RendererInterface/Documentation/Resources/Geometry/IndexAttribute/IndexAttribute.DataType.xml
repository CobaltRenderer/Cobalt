<XMLDocContent PageName="cobalt.graphics.IndexAttribute.DataType" Title="DataType enumeration" xmlns="http://www.cobaltrenderer.com/schema/XMLDocSchema.xsd">
  <Paragraph>
    <PageRef PageName="cobalt.graphics.Welcome">Home</PageRef> ->
    <PageRef PageName="cobalt.graphics.IndexAttribute">IndexAttribute</PageRef> ->
    DataType
  </Paragraph>
  <Section Title="Description">
    <Paragraph>
      The <TypeRef>DataType</TypeRef> enumeration identifies the scalar integer encoding used by an index attribute entry.
    </Paragraph>
  </Section>
  <Section Title="Members">
    <EnumMemberList>
      <EnumMemberListEntry Name="UInt16">
        Stores each index as a 16-bit unsigned integer.
      </EnumMemberListEntry>
      <EnumMemberListEntry Name="UInt32">
        Stores each index as a 32-bit unsigned integer.
      </EnumMemberListEntry>
    </EnumMemberList>
  </Section>
