<XMLDocContent PageName="cobalt.graphics.IndexAttribute.GetIndexCount" Title="GetIndexCount method" xmlns="http://www.cobaltrenderer.com/schema/XMLDocSchema.xsd">
  <Paragraph>
    <PageRef PageName="cobalt.graphics.Welcome">Home</PageRef> ->
    <PageRef PageName="cobalt.graphics.IndexAttribute">IndexAttribute</PageRef> ->
    GetIndexCount
  </Paragraph>
  <Section Title="Description">
    <Paragraph>
      The <TypeRef>GetIndexCount</TypeRef> method returns the number of indices accessible through this index attribute.
    </Paragraph>
  </Section>
  <Section Title="Usage">
    <Code Language="C++"><![CDATA[size_t GetIndexCount() const;]]></Code>
    <SubSection Title="Return value">
      <ReturnValue Type="size_t">
        The number of indices described by this index attribute.
      </ReturnValue>
    </SubSection>
  </Section>
