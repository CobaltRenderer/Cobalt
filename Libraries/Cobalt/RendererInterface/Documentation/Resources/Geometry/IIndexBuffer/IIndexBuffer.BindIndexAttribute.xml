<XMLDocContent PageName="cobalt.graphics.IIndexBuffer.BindIndexAttribute" Title="BindIndexAttribute method" xmlns="http://www.cobaltrenderer.com/schema/XMLDocSchema.xsd">
  <Paragraph>
    <PageRef PageName="cobalt.graphics.Welcome">Home</PageRef> ->
    <PageRef PageName="cobalt.graphics.IIndexBuffer">IIndexBuffer</PageRef> ->
    BindIndexAttribute
  </Paragraph>
  <Section Title="Description">
    <Paragraph>
      The <TypeRef>BindIndexAttribute</TypeRef> method binds the specified IndexAttribute as a member of the buffer.
    </Paragraph>
  </Section>
  <Section Title="Usage">
    <Code Language="C++"><![CDATA[SuccessToken BindIndexAttribute(IIndexAttribute& indexAttribute);]]></Code>
    <SubSection Title="Argument list">
      <ArgumentList>
        <ArgumentListEntry Type="IIndexAttribute" Name="indexAttribute">
          The index attribute to bind to this index buffer.
        </ArgumentListEntry>
      </ArgumentList>
    </SubSection>
    <SubSection Title="Return value">
      <ReturnValue Type="SuccessToken">
        True if the operation succeeded, false otherwise. An assertion will be raised in debug builds if the result is not tested.
      </ReturnValue>
    </SubSection>
  </Section>
  <Section Title="See also">
    <PageRefList>
      <PageRefListEntry PageName="cobalt.graphics.IIndexBuffer">IIndexBuffer</PageRefListEntry>
    </PageRefList>
  </Section>
</XMLDocContent>
