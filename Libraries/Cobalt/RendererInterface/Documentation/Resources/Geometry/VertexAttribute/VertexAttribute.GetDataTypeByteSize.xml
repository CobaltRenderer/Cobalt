<XMLDocContent PageName="cobalt.graphics.VertexAttribute.GetDataTypeByteSize" Title="GetDataTypeByteSize method" xmlns="http://www.cobaltrenderer.com/schema/XMLDocSchema.xsd">
  <Paragraph>
    <PageRef PageName="cobalt.graphics.Welcome">Home</PageRef> ->
    <PageRef PageName="cobalt.graphics.VertexAttribute">VertexAttribute</PageRef> ->
    GetDataTypeByteSize
  </Paragraph>
  <Section Title="Description">
    <Paragraph>
      The <TypeRef>GetDataTypeByteSize</TypeRef> method returns the size of a single vertex entry in bytes.
    </Paragraph>
  </Section>
  <Section Title="Usage">
    <Code Language="C++"><![CDATA[constexpr static size_t GetDataTypeByteSize(DataType dataType);]]></Code>
    <SubSection Title="Argument list">
      <ArgumentList>
        <ArgumentListEntry Type="DataType" Name="dataType">
          The attribute data type to query.
        </ArgumentListEntry>
      </ArgumentList>
    </SubSection>
    <SubSection Title="Return value">
      <ReturnValue Type="constexpr static size_t">
        The byte size of one scalar value of the specified data type.
      </ReturnValue>
    </SubSection>
  </Section>
  <Section Title="See also">
    <PageRefList>
      <PageRefListEntry PageName="cobalt.graphics.VertexAttribute">VertexAttribute</PageRefListEntry>
    </PageRefList>
  </Section>
</XMLDocContent>
