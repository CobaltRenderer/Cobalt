      <TypeMemberListEntry Visibility="Public" Name="ITextureBuffer1DArray" TypeCategory="Interface" PageName="cobalt.graphics.ITextureBuffer1DArray">
        An array of one dimensional texture resources
      </TypeMemberListEntry>
