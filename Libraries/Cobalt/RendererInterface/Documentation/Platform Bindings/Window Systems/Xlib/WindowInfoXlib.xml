        The Xlib display connection.
      </DataMemberListEntry>
      <DataMemberListEntry Visibility="Public" Type="::Window" Name="window">
        The Xlib window.
      </DataMemberListEntry>
      <DataMemberListEntry Visibility="Public" Type="V2UInt32" Name="windowSizeInPixels">
