    <SubSection Title="Initialization methods">
      <FunctionMemberList>
        <FunctionMemberListEntry Visibility="Public" Name="Initialize" PageName="cobalt.graphics.WindowSystemInfoSDL3.Initialize">
          Builds the platform-specific binding information from SDL state.
        </FunctionMemberListEntry>
      </FunctionMemberList>
    </SubSection>
    <SubSection Title="Data access methods">
      <FunctionMemberList>
        <FunctionMemberListEntry Visibility="Public" Name="GetType" PageName="cobalt.graphics.WindowSystemInfoSDL3.GetType">
          Returns the concrete platform binding type.
        </FunctionMemberListEntry>
        <FunctionMemberListEntry Visibility="Public" Name="Get" PageName="cobalt.graphics.WindowSystemInfoSDL3.Get">
