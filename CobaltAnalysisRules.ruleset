<?xml version="1.0" encoding="utf-8"?>
<RuleSet ToolsVersion="15.0" Name="Cobalt Analysis Rules" Description="Customized Cobalt renderer analysis rules">
  <Rules AnalyzerId="Microsoft.Analyzers.NativeCodeAnalysis" RuleNamespace="Microsoft.Rules.Native">
    <!-- We turn all these rules on by default, as they come as part of the "Microsoft Native Recommended" ruleset, and
    we accept them as our base recommendation too. -->
