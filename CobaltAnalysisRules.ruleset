    <!-- C26439 - SPECIAL_NOEXCEPT: We have no interest in scattering noexcept attributes around the entire codebase. -->
    <Rule Id="C26439" Action="None" />
    <!-- C6262 - Stack size analysis: We're not going to rely on static analysis to worry about function stack frame size. We can choose to
    use a lot of stack in some functions, and that's ok. -->
    <Rule Id="C6262" Action="None" />
    <!-- C26495 - MEMBER_UNINIT: This rule would be desirable, but it triggers on structure members too, where the structure is intended to
    be a trivial type. As we don't want to force the creation of non-default constructors in this case, the rule has been disabled. If there
    was a distinction made between classes and structures in C++, it would be our preference to have this on for classes and off for
    structures. -->
    <Rule Id="C26495" Action="None" />
    <!-- C6294 - Ill defined for loop : This rule would be really handy, except it causes problems with for loops that have constraints that
    are provided by constants or template parameters, where the loop is intended not to execute in the case the constraints aren't met. -->
    <Rule Id="C6294" Action="None" />
    <!-- C6201 - Buffer overrun : As a follow-on for the above rule C6294, this rule also triggers an error in the case of for loops where
    constrains aren't satisfied, which is a shame, as it would be really useful. -->
    <Rule Id="C6201" Action="None" />
    <!-- C26451 - Arithmetic overflow : Limited to multiplication this would be handy, but trivial +/- adjustments of integer indexes passed
    in as vector indexes trigger this warning everywhere in cases which are safe. -->
    <Rule Id="C26451" Action="None" />
    <!-- C26800 - Use of a moved object: This would be really handy, but it triggers for shared_ptr types when reusing after a move, which
    is safe. -->
    <Rule Id="C26800" Action="None" />
  </Rules>
  <Rules AnalyzerId="Microsoft.AnalyzerPowerPack.Common" RuleNamespace="Microsoft.AnalyzerPowerPack.Common">
    <!-- CA1012 - AbstractTypesShouldNotHaveConstructors: This is a sensible rule which is easy to follow. -->
    <Rule Id="CA1012" Action="Warning" />
    <!-- CA2235 - MarkAllNonSerializableFields: This rule currently fires erroneously against static members, which are not included in
    serialization. -->
    <Rule Id="CA2235" Action="Hidden" />
  </Rules>
  <Rules AnalyzerId="StyleCop.Analyzers" RuleNamespace="StyleCop.Analyzers">
    <!-- SA1004 - DocumentationLinesMustBeginWithSingleSpace: For consistency, all XML-based comment rules are disabled. See comment under
    StyleCop.CSharp.DocumentationRules. -->
    <Rule Id="SA1004" Action="None" />
    <!-- SA1005 - SingleLineCommentsMustBeginWithSingleSpace: As per SA1515, this fires for commented out source lines, even using the
    built-in comment out menu options facility in Visual Studio no less, as well as for "TODO" flags and the like. Some people may argue a
    space after opening a comment line adds to readability, and to a degree I agree, but not all comment lines are comments, nor do I believe
    StyleCop should restrict what is allowed here. -->
    <Rule Id="SA1005" Action="None" />
    <!-- SA1025 - CodeMustNotContainMultipleWhitespaceInARow: Where there are multiple similar elements in a row, and you want to pad out
    some whitespace here and there to align them into much more readable vertical columns, this rule flags it as an issue. Since this
    discourages what can in fact be a very good practice, this rule has been disabled here. It's a pity, since a warning for truly useless
    extra whitespace mid-line would be useful. -->
    <Rule Id="SA1025" Action="None" />
    <!-- SA1100 - DoNotPrefixCallsWithBaseUnlessLocalImplementationExists: Explicitly chosing to call a base implementation is unusual.
    I'd prefer to let a programmer choose to do so in case they have a good reason to want to do this as a defensive measure against
    code breakage for a potential future case where the method or property might be overridden or hidden. -->
    <Rule Id="SA1100" Action="None" />
    <!-- SA1101 - PrefixLocalCallsWithThis: StyleCop is here enforcing a particular naming convention for declaring and accessing member
    variables. We're opting at this time not to enforce a requirement around this. My personal preference would be to use leading underscores. -->
    <Rule Id="SA1101" Action="None" />
    <!-- SA1115 - ParameterMustFollowComma: Obsolete rule that breaks horribly when you have statement lambdas passed as arguments that are
    split across several lines for clarity, such as when invoking a method onto a dispatcher. This rule as it stands complains about the
    best practice approach in this area. If this rule could be updated to ignore cases where lambdas are used it would be of benefit. -->
    <Rule Id="SA1115" Action="None" />
    <!-- SA1116 - SplitParametersMustStartOnLineAfterDeclaration: Same problems currently as SA1115, and even if that wasn't the case, this
    is a poor convention to begin with in my opinion. -->
    <Rule Id="SA1116" Action="None" />
    <!-- SA1119 - StatementMustNotUseUnnecessaryParenthesis: Where some basic calculations are being done for method arguments, or when a
    return value is being specified using operators, parenthesis help readability by clearly grouping otherwise visually separate elements.
    In my opinion, the programmer should be free to use parenthesis whenever they feel it aids in the readability of the expression at hand,
    regardless of whether those parenthesis are technically required to express order of evaluation. -->
    <Rule Id="SA1119" Action="None" />
    <!-- SA1120 - CommentsMustContainText: This is disabled because as mentioned elsewhere, I don't believe StyleCop should interfere with
    the style or placement of comment blocks. -->
    <Rule Id="SA1120" Action="None" />
    <!-- SA1121 - UseBuiltInTypeAlias: This would be good if it was limited to variable or parameter declarations, but unfortunately it
    currently applies as a blanket rule across all code, including when accessing static members or methods of those inbuilt types. It's
    much more readable and cleaner to reference static members of built in types using their formal name, IE, Boolean.TryParse, rather
    than bool.TryParse. This rule doesn’t distinguish this case, and therefore should be disabled. -->
    <Rule Id="SA1121" Action="None" />
    <!-- SA1124 - DoNotUseRegions: We use regions for named grouping and organization of elements, and recommend turning off outlining by
    default. With outlining turned off, the only documented purpose for having this rule no longer applies. -->
    <Rule Id="SA1124" Action="None" />
    <!-- SA1126 - PrefixCallsCorrectly: In-line with SA1101 and other rules, we don't currently enforce any particular prefixing of
    members. Note that with StyleCop Analyzers, this rule is obsolete and no longer required. -->
    <!-- SA1129 - DoNotUseDefaultValueTypeConstructor: I disagree with the premise of this rule. Classes and structs have the same C#
    construction syntax, and using the "new T()" syntax makes it clear that a new object is being created, in this case with no arguments
    supplied to the constructor. After this call, a valid object will be returned ready for use, regardless of whether it is a reference
    or value type. On the other hand, using on the "default(T)" syntax will return a constructed object for a value type, and null for a
    reference type. If a struct is later changed to a class, which often occurs, if the default(T) syntax was being relied on to construct
    the object, that code will now fail at runtime. This rule promotes more dangerous, less consistent syntax, and should be disabled. -->
    <Rule Id="SA1129" Action="None" />
    <!-- SA1200 - UsingDirectivesMustBePlacedWithinNamespace: Goes totally against the grain of the inbuilt Visual Studio templates,
    as well as the majority of open source code. In addition, in my opinion, this pattern creates a problem rather than solving one. -->
    <Rule Id="SA1200" Action="None" />
    <!-- SA1201 - ElementsMustAppearInTheCorrectOrder: Corrent order is a matter of opinion, and in my opinion the ordering rules in
    StyleCop are poor. There’s no logical sequence to the order it enforces. In particular locating properties under constructors is
    a real pain, and runs counter to generally accepted best practice. If we were to enforce an order of elements, it would be
    strikingly different to the one proposed by StyleCop. -->
    <Rule Id="SA1201" Action="None" />
    <!-- SA1202 - ElementsMustBeOrderedByAccess: I strongly disagree. The best thing about the way access modifiers are applied in C#
    is that we can do away with the C++-oriented thinking of grouping members in this manner. Methods in particular should be grouped
    within a class based on logical associations and functional relationships, not split out into an arbitrary sequence based on access
    modifiers. We may as well say here that all classes should be partial and split public/private implementation across files if we
    think this rule is a good idea, because that would be a more logical end to that kind of thinking. -->
    <Rule Id="SA1202" Action="None" />
    <!-- SA1203 - ConstantsMustAppearBeforeFields: Disabled as per comment for SA1201. -->
    <Rule Id="SA1203" Action="None" />
    <!-- SA1204 - StaticElementsMustAppearBeforeInstanceElements: Disabled as per comment for SA1201. -->
    <Rule Id="SA1204" Action="None" />
    <!-- SA1205 - PartialElementsMustDeclareAccess: This rule would be desirable, but unfortunately it currently erroneously reports
    private partial classes as lacking an access modifier. This is fixed under the following issue:
    https://github.com/DotNetAnalyzers/StyleCopAnalyzers/issues/2040
    We're currently waiting for a new release version to include this fix, at which time this rule should be reactivated. -->
    <Rule Id="SA1205" Action="None" />
    <!-- SA1206 - DeclarationKeywordsMustFollowOrder: Disabled as per comment for SA1201. -->
    <Rule Id="SA1206" Action="None" />
    <!-- SA1207 - ProtectedMustComeBeforeInternal: Disabled as per comment for SA1201. -->
    <Rule Id="SA1207" Action="None" />
    <!-- SA1210 - UsingDirectivesMustBeOrderedAlphabeticallyByNamespace: This is nice, and I try and do it myself, but enforcing it
    through StyleCop might be overly pedantic. Visual Studio has also increasingly added more features and behaviour to try and get
    using statements ordered nicely on insertion and help the programmer clean up unnecessary statements. I'm inclined to defer towards
    that behaviour rather than flag issues at build time through StyleCop. I'm not sure we'd be gaining any real value with this option. -->
    <Rule Id="SA1210" Action="None" />
    <!-- SA1211 - UsingAliasDirectivesMustBeOrderedAlphabeticallyByAliasName: Disabled as per comment for SA1210. -->
    <Rule Id="SA1211" Action="None" />
    <!-- SA1214 - StaticReadonlyElementsMustAppearBeforeStaticNonReadonlyElements: Disabled as per comment for SA1201. -->
    <!-- SA1215 - InstanceReadonlyElementsMustAppearBeforeInstanceNonReadonlyElements: Disabled as per comment for SA1201. Note that
    SA1215 was combined into SA1214 for StyleCop Analyzers.-->
    <Rule Id="SA1214" Action="None" />
    <!-- SA1301: This rule currently does nothing. If that changes, we’ll want to decide to turn it on ourselves. -->
    <Rule Id="SA1301" Action="None" />
    <!-- SA1303 - ConstFieldNamesMustBeginWithUpperCaseLetter: This rule is good in principle, but it doesn't distinguish between
    method local constants and member constants, which ruins the usefulness of the rule. Until this is corrected, it must stay off. -->
    <Rule Id="SA1303" Action="None" />
    <!-- SA1304 - NonPrivateReadonlyFieldsMustBeginWithUpperCaseLetter: See comments for SA1311. -->
    <Rule Id="SA1304" Action="None" />
    <!-- SA1305: Hungarian notation is a horrible relic that should be done away with, but this rule isn't smart enough to detect
    it, and will object to names like "uiManager", "osVersion", "isAnnoying", and lots of other cases of two lowercase letters
    followed by an uppercase one. It also makes PInvoke on Win32 api functions trigger lots of warnings, or when adding manual
    WinProc hooks in WPF, since those method signatures, if defined correctly, do in fact use hungarian notation for their
    parameters. Since hungarian notation simply isn't used anymore in the real world, and this rule complains about perfectly
    valid names, it should be disabled. We won't gain any real advantage by leaving it on. -->
    <Rule Id="SA1305" Action="None" />
    <!-- SA1306 - FieldNamesMustBeginWithLowerCaseLetter: I agree with this rule. It's turned off right now only because there's a
    fair amount of existing code that used an m_SomeField naming scheme, and this rule ignores the m_ prefix and fires a warning for
    the following portion of the name. Once we've restyled all existing code away from this convention, this rule should be activated. -->
    <Rule Id="SA1306" Action="None" />
    <!-- SA1307 - AccessibleFieldsMustBeginWithUpperCaseLetter: See comments for SA1311. -->
    <Rule Id="SA1307" Action="None" />
    <!-- SA1308 - VariableNamesMustNotBePrefixed: See comments for SA1309. -->
    <Rule Id="SA1308" Action="None" />
    <!-- SA1309 - FieldNamesMustNotBeginWithUnderscore: StyleCop is here enforcing a particular naming convention for declaring and
    accessing member variables. We're opting at this time not to enforce a requirement around this. My personal preference would be
    to use leading underscores. -->
    <Rule Id="SA1309" Action="None" />
    <!-- SA1310 - FieldNamesMustNotContainUnderscore: See comments for SA1309. -->
    <Rule Id="SA1310" Action="None" />
    <!-- SA1311 - StaticReadonlyFieldsMustBeginWithUpperCaseLetter: I just flat out disagree with this. Static readonly fields
    shouldn't be exposed as public anymore than normal fields should be exposed as public. What you want here is a property, and
    making it named like a property doesn't make it one. Private static readonly fields should follow the same naming convention as
    any other kind of field. -->
    <Rule Id="SA1311" Action="None" />
    <!-- SA1400 - AccessModifierMustBeDeclared: All classes are internal unless made public (which should be the exception, not the
    general rule). All fields should be private, always, unless we’re in a struct. Since the presence of a keyword where one is not
    usually present is much more obvious and immediately apparent than a different keyword being provided in place of another
    (especially when they start with the same leading letter as in public/private), I believe providing no keyword for these two
    cases meets the goal better, that is, makes it immediately clearer to the programmer when something is falling into the "unusual"
    case. In my opinion, access modifiers should always be provided for methods, nested types, and properties however. I'd concede
    that fields require an explicit private access modifier for consistency within a class definition, however requiring "internal"
    for all classes is obsessive and unnecessary, and goes against the general trend in most open source C# projects, and the default
    settings for the Visual Studio C# templates themselves. I suggest implementing a relaxed version of this rule that enforces the
    concept for all type members, but ignores it for namespace members. Until such a rule exists, this should remain turned off. -->
    <Rule Id="SA1400" Action="None" />
    <!-- SA1412 - StoreFilesAsUtf8: This is a new rule with StyleCop Analyzers which is off by default, and we want to keep it off
    in the future even if the default changes. -->
    <Rule Id="SA1412" Action="None" />
    <!-- SA1501 - StatementMustNotBeOnSingleLine: Sometimes it's much better to put the statements on a single line, especially
    if you're trying to avoid catching System.Exception, and need to handle 10 different exceptions and do a quick one-liner in
    each catch statement. 10 lines becomes 40 if you stick by this rule, and it's undeniably harder to read and maintain. -->
    <Rule Id="SA1501" Action="None" />
    <!-- SA1502 - ElementMustNotBeOnSingleLine: This gets very annoying when you have constructors or base class methods for
    example with empty implementations. In these cases it is natural follow the open and close brace directly after each other
    on the same line. This rule also has lots of undocumented silent pass behaviour for many implicit exceptions to the rule,
    such as property getters and setters and statement lambdas. -->
    <Rule Id="SA1502" Action="None" />
    <!-- SA1512 - SingleLineCommentsMustNotBeFollowedByBlankLine: Same problems as with SA1515.-->
    <Rule Id="SA1512" Action="None" />
    <!-- SA1513 - ClosingCurlyBracketMustBeFollowedByBlankLine: Sounds like a good idea, but will often force separation between
    logically grouped code elements, especially in "initialize if not defined" cases. -->
    <Rule Id="SA1513" Action="None" />
    <!-- SA1514 - ElementDocumentationHeaderMustBePrecededByBlankLine: Sounds like a good idea, but the rule is implemented
    poorly, and doesn’t allow for leading comment lines before the summary tag. This imposes a restriction on how the comment
    itself needs to be structured, and since I believe comment formatting rules shouldn’t be handled by StyleCop, this rule also
    needs to be disabled. -->
    <Rule Id="SA1514" Action="None" />
    <!-- SA1515 - SingleLineCommentMustBePrecededByBlankLine: May sound good on the surface, but this rule also triggers for
    commented out source lines and "TODO" style tags. There is an exception where quad forwardslash can be used instead to make
    this rule ignore the line for these cases, but this just highlights how commonly this rule triggers for legitimate cases. I
    don't think this rule adds to the maintainability of code in any way, and since I also don't believe StyleCop should interfere
    with comments at all, and this rule in particular will trigger a lot of times, particularly with an incomplete set of changes,
    this rule is turned off. -->
    <Rule Id="SA1515" Action="None" />
    <!-- SA1516 - ElementsMustBeSeparatedByBlankLine: Very bad idea. Both properties and fields should be able to be listed
    without spaces betweeen them. -->
    <Rule Id="SA1516" Action="None" />
    <!-- StyleCop is a poor tool for managing structured code comments, and in my opinion, XML-based code documentation
    embedded inline within the code is poor to start with. You end up with inadequate documentation, and you severely
    hinder code readability in the process, especially when formally documenting short elements such as properties. You
    can't embed pictures in code comments or provide four pages of text with examples for instance, even though this
    level of depth is often needed for proper documentation. In my opinion, formal documentation and code should be kept
    separate, and comments should be left for informal free-form internal documentation where and how the programmer
    determines it should be used. If however we were to push for complete XML-based internal documentation in the future,
    it wouldn't be with as blunt a tool as StyleCop. It would need to be with something that at least had enough
    understanding to know that documenting an interface is sufficient, and an implementing type doesn't need to duplicate
    the same documentation for the implementation of those members. -->
    <Rule Id="SA1600" Action="None" />
    <Rule Id="SA1601" Action="None" />
    <Rule Id="SA1602" Action="None" />
